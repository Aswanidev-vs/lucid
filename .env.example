# Server
PORT=8080
APP_ENV=development

# Database (empty = SQLite; set to PostgreSQL connection string for production)
DATABASE_URL=

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production

# CORS (comma-separated origins, or * to allow all)
CORS_ORIGINS=http://localhost:8080

# Cookie (same-site: Strict, Lax, None)
COOKIE_SAMESITE=Lax
